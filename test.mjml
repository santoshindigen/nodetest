<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all color="#000000" font-family="Arial"></mj-all>
    </mj-attributes>
    <mj-style id="id_01">
      a:-webkit-any-link {
          cursor: auto;
        }
        img+div {
          display: none;
        }
        img.g-img+div {
          display: none;
        }
        u {
          text-decoration: underline!important;
        }
        .blueLink {
          color: blue !important;
          text-decoration: underline !important;
        }
        h1, h2, h3, h4, h5, h6 { margin:0; }
        table, td { border-collapse: inherit; }
        li {text-align:-webkit-match-parent; display:list-item;}
      	ul li {
      		margin-left: 0px !important;
      	}
        ol li {
      	  margin-left: 0px !important;
      	}
        ul li span, ol li span {
          display: inline !important;
        }
        .hideOnDesktop, .hideOnDesktop table, .hideOnDesktop p {
          display: none;
          mso-hide: all !important;
        }
        .hideOnDesktop-outlook, .hideOnDesktop-outlook table, .hideOnDesktop-outlook p {
            display: none !important;
            mso-hide: all !important;
        }
        @media (max-width:480px) {
          .hideOnMobile {
            display: none !important;
          }
          .hideOnDesktop, .hideOnDesktop p {
            display: block !important;
          }
          .hideOnDesktop table {
            display: table !important
          }
          .hideOnDesktop-outlook, .hideOnDesktop-outlook p{
            display: block !important;
          }
			    .hideOnDesktop-outlook table {
            display: table-cell !important;
          }
          .mobileResponsive {
            display: inline-block !important;
            width: 100% !important;
          }
        }
    </mj-style>
    <mj-style id="sub">
      sub{
                  line-height: 0;
                  font-size: 8px;
                  vertical-align: -4px;
              }
              sub > font
                {
                  font-size: 8px;
                  display: inherit;
                }
    </mj-style>
    <mj-raw>
      <!--[if gte mso 9]>
                    <style>
                      li {
                        text-indent: -1em;
                      }
                    </style>
                  <![endif]-->
    </mj-raw>
    <mj-style id="padDeskMob">
      @media (max-width:480px) {
    .element_5j8cg {
        padding: undefined undefined undefined undefined !important
    }
    .element_4e7oi {
        padding: 10px 25px 10px 25px !important
    }
}
    </mj-style>
    <mj-style id="sup">
                    sup{
                  line-height: 0;
                  font-size: 8px;
                  vertical-align: 4px;
              }
              sup > font
                {
                  font-size: 8px;
                  display: inherit;
                }
    </mj-style>
  </mj-head>
  <mj-body background-color="#ffffff" width="600px">
